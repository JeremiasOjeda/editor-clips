# ============================================
# Editor de Clips - Variables de entorno
# ============================================
# Copia este archivo como .env y reemplaza los valores por los de tu entorno.
# NUNCA subas tu archivo .env al repositorio.

# Entorno de ejecución: development | production
NODE_ENV=development

# Puerto en el que corre el servidor Express (backend)
PORT=5000

# URI de conexión a MongoDB
# Local:  mongodb://localhost:27017/editor-clips
# Atlas:  mongodb+srv://<user>:<password>@<cluster>/editor-clips
MONGODB_URI=mongodb://localhost:27017/editor-clips

# URL base de la API que consume el cliente React
REACT_APP_API_URL=http://localhost:5000/api
